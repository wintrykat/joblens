{
  "name": "joblens",
  "version": "1.6.0",
  "private": true,
  "description": "Chrome extension for AI-assisted job-posting triage (manual scan).",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "typecheck": "tsc --noEmit",
    "build": "tsc --noEmit && vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "smoke": "npm run build && tsx scripts/smoke.ts",
    "icons": "node scripts/render-icons.mjs",
    "pack:zip": "tsx scripts/pack-zip.ts",
    "pack:crx": "tsx scripts/pack-crx.ts",
    "pack": "npm run build && npm run pack:crx"
  },
  "dependencies": {
    "mammoth": "^1.12.0",
    "pdfjs-dist": "^6.1.200",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@crxjs/vite-plugin": "^2.0.0-beta.28",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/chrome": "^0.0.287",
    "@types/node": "^22.13.10",
    "@types/react": "^18.3.18",
    "@types/react-dom": "^18.3.5",
    "@vitejs/plugin-react": "^6.0.4",
    "@vitest/coverage-v8": "^4.1.10",
    "crx3": "^2.0.0",
    "jsdom": "^29.1.1",
    "sharp": "^0.35.3",
    "tsx": "^4.19.3",
    "typescript": "^5.7.3",
    "vite": "^8.1.5",
    "vitest": "^4.1.10"
  }
}
