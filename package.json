{
  "name": "joblens",
  "version": "1.0.1",
  "private": true,
  "description": "Chrome extension for AI-assisted job-posting triage (manual scan).",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "typecheck": "tsc --noEmit",
    "build": "tsc --noEmit && vite build",
    "preview": "vite preview",
    "smoke": "npm run build && tsx scripts/smoke.ts",
    "pack:crx": "tsx scripts/pack-crx.ts",
    "pack": "npm run build && npm run pack:crx"
  },
  "dependencies": {
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@crxjs/vite-plugin": "^2.0.0-beta.28",
    "@types/chrome": "^0.0.287",
    "@types/node": "^22.13.10",
    "@types/react": "^18.3.18",
    "@types/react-dom": "^18.3.5",
    "@vitejs/plugin-react": "^4.3.4",
    "crx3": "^2.0.0",
    "tsx": "^4.19.3",
    "typescript": "^5.7.3",
    "vite": "^5.4.11"
  }
}
